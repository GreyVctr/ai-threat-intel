# AI Shield Intelligence - Minimal Local Profile
# Environment Configuration Template
#
# Copy this file to .env.minimal and update with your values:
#   cp .env.example .env.minimal

# =============================================================================
# REQUIRED CONFIGURATION
# =============================================================================

# PostgreSQL Database
POSTGRES_PASSWORD=changeme_secure_password_here

# MinIO Object Storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_secure_password_here

# =============================================================================
# OPTIONAL CONFIGURATION (defaults provided)
# =============================================================================

# Admin User Credentials (for automated setup)
# These are used by scripts/create_admin.py for non-interactive admin creation
# Leave blank to use interactive mode (prompts for input)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=AdminPass123

# Service Ports
# Change these if you have port conflicts with existing services
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
OLLAMA_PORT=11434
API_PORT=8000
FRONTEND_PORT=3000

# Environment Mode
# Options: development, production
# - development: Relaxed security validation, verbose logging, hot-reload enabled
# - production: Strict security validation, JSON logging, enforces strong passwords
ENVIRONMENT=development

# Ollama LLM Model
# Options: qwen2.5:7b (recommended), phi3:mini (faster/smaller), qwen2.5:14b (higher quality)
# Default: qwen2.5:7b - optimized for technical threat analysis
# OLLAMA_MODEL=qwen2.5:7b

# Ollama Configuration
# Option 1 (Default): Use containerized Ollama (CPU-only on macOS)
#   - Fully containerized, easier to manage
#   - CPU-only processing (no GPU acceleration on macOS)
#   - Speed: ~15-40 seconds per threat
# OLLAMA_URL=http://ollama:11434

# Option 2 (Recommended for macOS): Use host Ollama with GPU acceleration
#   - Requires Ollama installed on host: brew install ollama
#   - Uses Apple Silicon GPU/Neural Engine (3-6x faster)
#   - Speed: ~3-10 seconds per threat
#   - Uncomment the line below to use host Ollama:
# OLLAMA_URL=http://host.docker.internal:11434

# Ollama Timeout (seconds)
# Increase if you have many concurrent workers or slow LLM responses
# OLLAMA_TIMEOUT=30

# =============================================================================
# HYBRID THREAT CLASSIFICATION (optional)
# =============================================================================

# Classification Confidence Thresholds
# These control when the system uses keyword-only vs hybrid (keyword+LLM) classification
# 
# HIGH_THRESHOLD: Minimum keyword matches for high confidence (keyword-only, fast path)
#   - Default: 5 matches → Use keyword result directly, skip LLM (~100ms)
#   - Higher value → More conservative, more LLM calls
#   - Lower value → More aggressive, fewer LLM calls
# CLASSIFICATION_HIGH_THRESHOLD=5
#
# MEDIUM_THRESHOLD: Minimum keyword matches for medium confidence (hybrid validation)
#   - Default: 2 matches → Validate keyword result with LLM (~3-10s)
#   - Scores below this trigger LLM-only classification
# CLASSIFICATION_MEDIUM_THRESHOLD=2
#
# Classification Flow:
#   - Score ≥ 5: High confidence → Keyword-only (fast)
#   - Score 2-4: Medium confidence → Hybrid (keyword + LLM validation)
#   - Score 0-1: Low/no confidence → LLM-only (fallback)

# =============================================================================
# ALERT CONFIGURATION (optional)
# =============================================================================

# Enable/Disable Alerts
# Set to true to enable alert notifications
ALERT_ENABLED=false

# Alert Severity Threshold (1-10)
# Only threats with severity >= this value will trigger alerts
# Recommended: 8 for production, 6 for development
ALERT_SEVERITY_THRESHOLD=8

# Email Alerts
ALERT_EMAIL_ENABLED=false
# ALERT_EMAIL_SMTP_HOST=smtp.gmail.com
# ALERT_EMAIL_SMTP_PORT=587
# ALERT_EMAIL_FROM=alerts@example.com
# ALERT_EMAIL_TO=["security-team@example.com","admin@example.com"]
# ALERT_EMAIL_USERNAME=alerts@example.com
# ALERT_EMAIL_PASSWORD=your-app-password

# Webhook Alerts (Slack, Discord, custom endpoints)
ALERT_WEBHOOK_ENABLED=false
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# ALERT_WEBHOOK_METHOD=POST
# ALERT_WEBHOOK_HEADERS={"Content-Type": "application/json"}

# Note: For Gmail, use an App Password instead of your regular password
# Generate one at: https://support.google.com/accounts/answer/185833

# =============================================================================
# SERVICE URLS (automatically configured, no need to change)
# =============================================================================

# These are constructed from the above settings and used internally
# DATABASE_URL=postgresql+asyncpg://ai_shield:${POSTGRES_PASSWORD}@postgres:5432/ai_shield
# REDIS_URL=redis://redis:6379/0
# MINIO_ENDPOINT=minio:9000
# OLLAMA_URL=http://ollama:11434
# VITE_API_URL=http://localhost:${API_PORT}

# =============================================================================
# NOTES
# =============================================================================

# 1. Security: Never commit .env.minimal to version control
# 2. Passwords: Use strong passwords (min 16 characters, mixed case, numbers, symbols)
# 3. Ports: Ensure configured ports are not in use by other services
# 4. Resources: Minimum 8GB RAM, 4 CPU cores, 50GB disk space required
# 5. Docker: Requires Docker Engine (Linux) or OrbStack (macOS)
